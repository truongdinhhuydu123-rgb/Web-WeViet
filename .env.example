# Copy this file to .env on the server. Never commit real values.
NODE_ENV=production
PORT=3000
SESSION_SECRET=replace_with_a_long_random_secret_at_least_32_chars
ADMIN_CODE_HASH=replace_with_hash_from_npm_run_setup_admin
TOTP_SECRET=replace_with_totp_secret_from_npm_run_setup_admin
ADMIN_SESSION_HOURS=8
ALLOWED_ORIGIN=https://your-domain.com
DATABASE_URL=postgresql://user:password@host:5432/weviet

